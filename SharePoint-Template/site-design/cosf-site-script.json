{
  "$schema": "https://developer.microsoft.com/json-schemas/core-build/site-design/2019-02/site-script.schema.json",
  "version": 1,
  "actions": [

    {
      "verb": "applyTheme",
      "themeName": "City of South Fulton"
    },

    {
      "verb": "setSiteLogo",
      "url": "{siteUrl}/_layouts/15/userphoto.aspx",
      "_note": "Replace with your actual logo URL after upload"
    },

    {
      "verb": "setSiteExternalSharingCapability",
      "capability": "Disabled",
      "_note": "Intranet — internal-only sharing"
    },

    {
      "verb": "setRegionalSettings",
      "timeZone": 11,
      "_note": "11 = Eastern Time (US & Canada)"
    },

    {
      "verb": "addNavLink",
      "url": "/",
      "displayName": "Home",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/city-managers-office.aspx",
      "displayName": "City Manager's Office",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/human-resources.aspx",
      "displayName": "Human Resources",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/information-technology.aspx",
      "displayName": "Information Technology",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/communications.aspx",
      "displayName": "Communications",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/general-services.aspx",
      "displayName": "General Services",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "addNavLink",
      "url": "/SitePages/departments.aspx",
      "displayName": "Departments",
      "isWebRelative": true,
      "navLinkType": "global"
    },

    {
      "verb": "createSPList",
      "listName": "City Announcements",
      "templateType": 104,
      "_note": "Announcements list — preserves existing items",
      "subactions": [
        {
          "verb": "addSPField",
          "fieldType": "Text",
          "displayName": "Category",
          "isRequired": false,
          "addToDefaultView": true
        },
        {
          "verb": "addSPField",
          "fieldType": "Choice",
          "displayName": "Priority",
          "isRequired": false,
          "addToDefaultView": true,
          "choices": ["High", "Normal", "Low"]
        }
      ]
    },

    {
      "verb": "createSPList",
      "listName": "City Events Calendar",
      "templateType": 106,
      "_note": "Events list for calendar web part"
    },

    {
      "verb": "createSPList",
      "listName": "Department Directory",
      "templateType": 100,
      "_note": "Generic list for department contacts",
      "subactions": [
        {
          "verb": "addSPField",
          "fieldType": "Text",
          "displayName": "Department Name",
          "isRequired": true,
          "addToDefaultView": true
        },
        {
          "verb": "addSPField",
          "fieldType": "Text",
          "displayName": "Director",
          "isRequired": false,
          "addToDefaultView": true
        },
        {
          "verb": "addSPField",
          "fieldType": "Text",
          "displayName": "Phone",
          "isRequired": false,
          "addToDefaultView": true
        },
        {
          "verb": "addSPField",
          "fieldType": "Text",
          "displayName": "Email",
          "isRequired": false,
          "addToDefaultView": true
        },
        {
          "verb": "addSPField",
          "fieldType": "Choice",
          "displayName": "Category",
          "isRequired": false,
          "addToDefaultView": true,
          "choices": [
            "Public Safety",
            "Administration",
            "Infrastructure",
            "Development",
            "Technology",
            "Legal",
            "Justice",
            "Operations",
            "Enforcement",
            "Quality of Life"
          ]
        },
        {
          "verb": "addSPField",
          "fieldType": "Note",
          "displayName": "Description",
          "isRequired": false,
          "addToDefaultView": false
        }
      ]
    }

  ]
}
